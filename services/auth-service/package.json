{
  "name": "@enterprise/auth-service",
  "version": "1.0.0",
  "description": "Enterprise Authentication & Authorization Microservice",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:security": "npm audit && snyk test",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "docker:build": "docker build -t enterprise-auth-service .",
    "docker:run": "docker run -p 3001:3001 enterprise-auth-service",
    "k8s:deploy": "kubectl apply -f k8s/",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.10.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "passport": "^0.6.0",
    "passport-oauth2": "^1.7.0",
    "passport-saml": "^3.2.4",
    "passport-local": "^1.0.0",
    "passport-jwt": "^4.0.1",
    "node-saml": "^4.0.5",
    "pg": "^8.11.3",
    "redis": "^4.6.8",
    "ioredis": "^5.3.2",
    "knex": "^2.5.1",
    "objection": "^3.1.1",
    "joi": "^17.9.2",
    "uuid": "^9.0.0",
    "crypto": "^1.0.1",
    "nodemailer": "^6.9.4",
    "twilio": "^4.15.0",
    "axios": "^1.5.0",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "dotenv": "^16.3.1",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "express-brute": "^1.0.1",
    "express-brute-redis": "^0.0.1",
    "ua-parser-js": "^1.0.35",
    "geoip-lite": "^1.4.7",
    "device-detector-js": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "eslint": "^8.47.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-security": "^1.7.1",
    "snyk": "^1.1200.0",
    "@types/jest": "^29.5.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "authentication",
    "authorization",
    "microservice",
    "enterprise",
    "security",
    "oauth",
    "saml",
    "mfa",
    "rbac"
  ]
}
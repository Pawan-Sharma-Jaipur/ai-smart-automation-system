{
  "info": {
    "name": "AI Automation System API",
    "description": "Complete API collection for testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"test123\"\n}"
            },
            "url": "http://localhost:5000/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "http://localhost:5000/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "AI Automation",
      "item": [
        {
          "name": "Predict Automation",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hour\": 14,\n  \"usageCount\": 25,\n  \"context\": 1\n}"
            },
            "url": "http://localhost:5000/api/ai/predict"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Assign Role",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_ADMIN_JWT_TOKEN"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"role\": \"Admin\"\n}"
            },
            "url": "http://localhost:5000/api/admin/assign-role"
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer YOUR_ADMIN_JWT_TOKEN"}
            ],
            "url": "http://localhost:5000/api/admin/users"
          }
        },
        {
          "name": "Get All Logs",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer YOUR_ADMIN_JWT_TOKEN"}
            ],
            "url": "http://localhost:5000/api/admin/logs"
          }
        }
      ]
    },
    {
      "name": "Blockchain",
      "item": [
        {
          "name": "Log to Blockchain",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"USER_LOGIN\"\n}"
            },
            "url": "http://localhost:5000/api/blockchain/log"
          }
        },
        {
          "name": "Get Blockchain Logs",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer YOUR_JWT_TOKEN"}
            ],
            "url": "http://localhost:5000/api/blockchain/logs"
          }
        }
      ]
    }
  ]
}
